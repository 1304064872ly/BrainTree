# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/brain_tree

# LLM服务配置
# 支持: deepseek, openai, claude, zhipu
LLM_PROVIDER=deepseek

# API 密钥
# DeepSeek: 从 https://platform.deepseek.com 获取
# OpenAI: 从 https://platform.openai.com 获取
LLM_API_KEY=your_api_key_here

# API 基础 URL (可选)
# DeepSeek: https://api.deepseek.com (默认)
# OpenAI: https://api.openai.com/v1 (默认)
LLM_API_BASE=

# 模型名称 (可选)
# DeepSeek 模型: deepseek-chat, deepseek-coder, deepseek-reasoner, deepseek-v3, deepseek-r1
# OpenAI 模型: gpt-3.5-turbo, gpt-4, gpt-4-turbo
LLM_MODEL=deepseek-chat

# 服务器配置
HOST=0.0.0.0
PORT=8000
